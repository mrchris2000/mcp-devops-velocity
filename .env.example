# MCP DevOps Velocity Configuration
# Copy this file to .env and fill in your actual values

# Personal access token for Velocity API authentication
VELOCITY_ACCESS_TOKEN=your_base64_encoded_token_here

# Velocity GraphQL URL
VELOCITY_GRAPHQL_URL=https://your-velocity-server.com/graphql

# Tenant ID for your Velocity instance
VELOCITY_TENANT_ID=your-tenant-id-here

# Optional: path to a PEM file containing your internal/root CA certificate chain
VELOCITY_TLS_CA_FILE=

# Optional: set to true only for non-production/testing when using self-signed certs
VELOCITY_ALLOW_SELF_SIGNED_CERTS=false

# Optional: enables stderr debug logging without breaking MCP stdio messages
VELOCITY_DEBUG=false
